# Booksmith Configuration
# Copy this file to .env and fill in your values

# API Key (required)
ANTHROPIC_API_KEY=your_api_key

# Remote model config (zenmux or other providers)
ANTHROPIC_BASE_URL=https://zenmux.ai/api/anthropic
ANTHROPIC_REMOTE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_REMOTE_CONTEXT=128000

# Local model config (e.g., Ollama)
LOCAL_BASE_URL=http://localhost:11434/v1
ANTHROPIC_LOCAL_MODEL=mistralai/mistral-nemo-instruct-2407
ANTHROPIC_LOCAL_CONTEXT=32768

# Timeout in seconds
ANTHROPIC_TIMEOUT=120

# Default minimum words per chapter
DEFAULT_MIN_WORDS=2000

# Temperature settings (optional)
# Default temperature for all stages (0.0-1.0)
DEFAULT_TEMPERATURE=0.7

# Per-stage temperature overrides (optional)
# TEMP_STORY_BIBLE=0.7
# TEMP_WORLD_BUILDER=0.7
# TEMP_CHARACTERS=0.7
# TEMP_CHAPTER_OUTLINER=0.7
# TEMP_CHAPTER_WRITER=0.8
# TEMP_REVIEWER=0.5
# TEMP_OUTLINE_REVIEWER=0.5
# TEMP_MACRO_SUMMARY=0.5
