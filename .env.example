# Booksmith Configuration
# Copy this file to .env and fill in your values

# API Key (required)
# Use ANTHROPIC_AUTH_TOKEN for proxies/gateways with bearer tokens
# Use ANTHROPIC_API_KEY for direct Anthropic API access
ANTHROPIC_AUTH_TOKEN=your_auth_token

# Base URL (optional - for proxies/gateways)
# Leave unset to use the Anthropic SDK default
ANTHROPIC_BASE_URL=https://your-gateway-url

# Model configuration
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-20250514
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-20250514

# Context windows (optional)
ANTHROPIC_HAIKU_CONTEXT=128000
ANTHROPIC_SONNET_CONTEXT=128000
ANTHROPIC_OPUS_CONTEXT=128000

# Timeout in milliseconds
API_TIMEOUT_MS=120000

# Default minimum words per chapter
DEFAULT_MIN_WORDS=1500

# Temperature settings (optional)
# Default temperature for all stages (0.0-1.0)
DEFAULT_TEMPERATURE=0.7

# Per-stage temperature overrides (optional)
# TEMP_STORY_BIBLE=0.7
# TEMP_WORLD_BUILDER=0.7
# TEMP_CHARACTERS=0.7
# TEMP_CHAPTER_OUTLINER=0.7
# TEMP_CHAPTER_WRITER=0.8
# TEMP_REVIEWER=0.5
# TEMP_OUTLINE_REVIEWER=0.5
# TEMP_MACRO_SUMMARY=0.5
