# Booksmith Configuration
# Copy this file to .env and fill in your values

# API Key (required)
ANTHROPIC_API_KEY=your_api_key

# Remote model config (zenmux or other providers)
ANTHROPIC_BASE_URL=https://zenmux.ai/api/anthropic
ANTHROPIC_REMOTE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_REMOTE_CONTEXT=128000

# Local model config (e.g., Ollama)
LOCAL_BASE_URL=http://localhost:11434/v1
ANTHROPIC_LOCAL_MODEL=mistralai/mistral-nemo-instruct-2407
ANTHROPIC_LOCAL_CONTEXT=32768

# Timeout in seconds
ANTHROPIC_TIMEOUT=120
